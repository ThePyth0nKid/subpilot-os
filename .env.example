# SubPilot OS — environment template. Copy to .env.local and fill in. NEVER commit .env.local.

# --- Core ---
DAYTONA_API_KEY=                      # required: spins up the sandboxes
DAYTONA_API_URL=https://app.daytona.io/api
ANTHROPIC_API_KEY=                    # required: geo-research extraction
TAVILY_API_KEY=                       # optional: mock search used if empty

# --- Geo routing (stretch; mock used if empty) ---
# Adding these flips mock → real residential proxy with ZERO call-site changes.
# Stage-1 login proof REFUSES a real session cookie unless BRIGHTDATA_* is set
# (a datacenter egress would risk the account).
BRIGHTDATA_HOST=
BRIGHTDATA_PORT=
BRIGHTDATA_USERNAME=
BRIGHTDATA_PASSWORD=
# Comma-separated CIDRs the sandbox may egress to (Bright Data proxy range).
# REQUIRED to run a real-cookie Stage-1 proof — egress is fail-closed without it.
SANDBOX_NETWORK_ALLOWLIST=

# --- Payment (stretch; mock used if empty) ---
BITREFILL_API_KEY=
BITREFILL_API_SECRET=

# --- Auth: WorkOS AuthKit (optional; open demo mode until provided) ---
WORKOS_API_KEY=
WORKOS_CLIENT_ID=
WORKOS_COOKIE_PASSWORD=          # 32+ chars; generate a strong random string
NEXT_PUBLIC_WORKOS_REDIRECT_URI=http://localhost:3000/callback

# --- Persistence: Postgres (optional; in-memory only until provided) ---
# e.g. postgresql://user:pass@localhost:5432/subpilot  — then run: npm run db:push
DATABASE_URL=

# --- Payment: Stripe (optional, TEST mode) ---
STRIPE_SECRET_KEY=                    # sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=   # pk_test_...

# --- Privacy: optional account-holder name redaction (structural redaction is always on) ---
# Comma-separated names stripped from statement descriptions, e.g. "Max Mustermann,M. Mustermann".
# Empty = structural redaction only (IBAN, long digit runs, emails, card PANs).
HOLDER_NAMES=

# --- Stage-1 login proof (smoke only; NEVER commit a real value) ---
# A throwaway test account's session cookie for `npm run smoke:login-proof`.
# Default is a safe "test:" dummy. A real cookie also requires BRIGHTDATA_* +
# SANDBOX_NETWORK_ALLOWLIST and self-hosting (single-tenant).
TEST_SESSION_TOKEN=

# --- App ---
NEXT_PUBLIC_APP_NAME=SubPilot OS
