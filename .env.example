# SubPilot OS — environment template. Copy to .env.local and fill in. NEVER commit .env.local.

# --- Core (required for the demo) ---
DAYTONA_API_KEY=
DAYTONA_API_URL=https://app.daytona.io/api
ANTHROPIC_API_KEY=
TAVILY_API_KEY=

# --- Geo routing (stretch; mock used if empty) ---
BRIGHTDATA_HOST=
BRIGHTDATA_PORT=
BRIGHTDATA_USERNAME=
BRIGHTDATA_PASSWORD=

# --- Payment (stretch; mock used if empty) ---
BITREFILL_API_KEY=
BITREFILL_API_SECRET=

# --- Auth: WorkOS AuthKit (optional; open demo mode until provided) ---
WORKOS_API_KEY=
WORKOS_CLIENT_ID=
WORKOS_COOKIE_PASSWORD=          # 32+ chars; generate a strong random string
NEXT_PUBLIC_WORKOS_REDIRECT_URI=http://localhost:3000/callback

# --- Persistence: Postgres (optional; in-memory only until provided) ---
# e.g. postgresql://user:pass@localhost:5432/subpilot  — then run: npm run db:push
DATABASE_URL=

# --- Payment: Stripe (optional, TEST mode) ---
STRIPE_SECRET_KEY=                    # sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=   # pk_test_...

# --- Rate limiting (optional; in-memory, per-instance, ON by default) ---
# Fixed-window caps per identity (signed-in user id, else client IP).
RATE_LIMIT_DISABLED=                 # set to 1/true to turn off (e.g. load tests)
RATE_LIMIT_RUN_PER_MINUTE=5          # POST /api/run (fans out Daytona + LLM + Tavily)
RATE_LIMIT_ACT_PER_MINUTE=5          # POST /api/act (sandboxed switch execution)
RATE_LIMIT_STRIPE_PER_MINUTE=10      # POST /api/stripe/setup-intent

# --- App ---
NEXT_PUBLIC_APP_NAME=SubPilot OS
